# =============================================================================
# FILE:        SENSOR_IC.lim
# DEVICE:      SENSOR_IC — Dummy SPI Accelerometer
# TESTER:      Advantest V93000 PS1600 / SmarTest 7
# DESCRIPTION: Limit Table — maps test numbers to test names, lo/hi limits,
#              units, pass bin, and fail bin
#              Mirrors test suite sequence defined in SENSOR_IC.tf
#              Referenced by TESTSET().judgeAndLog_*() in test methods
# FORMAT:      test_num | test_name | lo_limit | hi_limit | unit | pass_bin | fail_bin
# REVISION:    1.0
# =============================================================================

LIMITTABLE SENSOR_IC_limits {

# ─────────────────────────────────────────────────────────────────────────────
